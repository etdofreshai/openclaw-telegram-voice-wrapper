# Telegram MTProto user API credentials
# Get these at: https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# gramjs StringSession — run `npm run generate-session` to get this
TELEGRAM_SESSION_STRING=

# (Optional) The Telegram chat to auto-select on startup.
# If not set, you'll pick a chat from the UI after connecting.
# Can be a username (@openclaw_bot), numeric ID (-1001234567890 for groups), etc.
TELEGRAM_TARGET_CHAT_ID=

# Backend port (dev only — Express runs here while Vite proxies to it)
BACKEND_PORT=3001

# Frontend port (optional, defaults to 3000)
FRONTEND_PORT=3000

# Frontend password (optional). If set, users must enter this password
# before accessing the UI. Leave empty to skip authentication.
FRONTEND_AUTH_PASSWORD=
